local function filter(parentObj, rarity)
	parentObj:ClearAllChildren()
	Instance.new("UICorner", parentObj)
	
	local c = 0
	for name, list in pairs(ConfigObj.Defenders) do
		if list.Rarity == rarity then
			c += 1
			local btn = Instance.new("TextButton", parentObj)
			btn.Size = UDim2.new(1, -10, 0, 35)
			btn.Position = UDim2.new(0, 5, 0, (c - 1) * 40)
			btn.Text = string.format("%s - %s$", name, DataObj[name][1].Price)
			btn.Font = Enum.Font.Gotham
			btn.TextSize = 15
			btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
			btn.TextColor3 = Color3.new(0.760784, 0.760784, 0.760784)
			Instance.new("UICorner", btn)
			
			local clone = gradients:FindFirstChild(rarity):Clone()
			clone.Parent = btn
			
			btn.MouseButton1Click:Connect(function()
				selectedTower = name
				parentObj.Parent.NameLabel.Text = name
			end)
		end
	end
	parentObj.CanvasSize = UDim2.new(0, 0, 0, 40 * c)
end
