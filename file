local function Upgrade(tower)
	task.wait(2)
	
	local nameBlock = tower:GetAttibute("OriginalName")
	repeat
		wait(0.1)
		local level = tower:GetAttibute("Level")
		print(level, DataObj[nameBlock][level + 1].Price, money.Value)
		if money.Value >= DataObj[nameBlock][level + 1].Price then
			local args = {
				tower
			}
			
			game.ReplicatedStorage.ModuleLoader.Shared.Network.RemoteFunction.UpgradeDefender:InvokeServer(unpack(args))
		end
		
	until not tower.Configuration.Upgrade
	
	return true
end

autoupgardeButton.MouseButton1Click:Connect(function()
	if not selectedTower then return end
	local conn
	conn = mouse.Button1Down:Connect(function()
		local args

		args = {

			selectedTower,
			LocalPlayer.Character.HumanoidRootPart.CFrame - Vector3.new(0, 0.7, 0),
			0
		}

		game.ReplicatedStorage.ModuleLoader.Shared.Network.RemoteFunction.SpawnDefender:InvokeServer(unpack(args))
		
		
		local save = selectedTower
		
		local add
		local tower
		
		if save then
			add = game.Workspace.Defenders.ChildAdded:Connect(function(child)
				if child.Name == save then
					local tower = child
					Upgrade(tower)
					add:Disconnect()
				end
			end)
		end
			
		conn:Disconnect()
	end)
end)
